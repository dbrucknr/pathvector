# GZipped Routing Test Files
*.gz

# Rust build artifacts
/target
pathvector-fuzz/target/

# Fuzz — corpus is NOT committed. A growing, effectively-binary corpus is a
# poor fit for git history (every blob stays forever, even after an entry is
# minimized away or superseded) — CI instead caches it across runs via
# actions/cache (see .github/workflows/ci.yml's fuzz job), which gets the
# same "don't start from empty every run" benefit without the repo bloat.
# Artifacts are crash reproducers that should be investigated and fixed, not
# stored long-term. Coverage data is generated on demand, not tracked.
pathvector-fuzz/corpus/
pathvector-fuzz/artifacts/
pathvector-fuzz/coverage/

# Editor — project-level configs are committed (.zed/settings.json) so that
# LSP and other shared settings work for all contributors. Only personal /
# machine-specific overrides belong here.
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.cargo-linux-cache/
book/
.claude/
