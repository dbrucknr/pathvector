# GZipped Routing Test Files
*.gz

# Rust build artifacts
/target
fuzz/target/

# Fuzz — corpus is committed (accumulated fuzzer knowledge used by CI).
# Artifacts are crash reproducers that should be investigated and fixed, not
# stored long-term. Coverage data is generated on demand, not tracked.
fuzz/artifacts/
fuzz/coverage/

# Editor — project-level configs are committed (.zed/settings.json) so that
# LSP and other shared settings work for all contributors. Only personal /
# machine-specific overrides belong here.
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.cargo-linux-cache/
book/
.claude/
